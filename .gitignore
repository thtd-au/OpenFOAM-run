# -----------------------------------------------------------------------------
# OpenFOAM build products
# -----------------------------------------------------------------------------
platforms/
**/lnInclude/
*.dep
*.o
*.so
*.a
*.la

# -----------------------------------------------------------------------------
# Dynamic runtime compilation
# -----------------------------------------------------------------------------
dynamicCode/
codeStream/

# -----------------------------------------------------------------------------
# Parallel decomposition
# -----------------------------------------------------------------------------
**/processor*/
**/processors*/

# -----------------------------------------------------------------------------
# Sandbox work area
# -----------------------------------------------------------------------------
sandbox/

# -----------------------------------------------------------------------------
# Test meshes / scratch data
# -----------------------------------------------------------------------------
meshes/test/

# -----------------------------------------------------------------------------
# Post processed data
# -----------------------------------------------------------------------------
post/data/

# -----------------------------------------------------------------------------
# Time directories and solver results
# Keep initial conditions in /0
# -----------------------------------------------------------------------------
**/[1-9]*/
**/[1-9]*.[0-9]*/
**/0.[0-9]*/
**/-[0-9]*/

# Explicitly keep initial conditions
!**/0/
!**/0/**

# -----------------------------------------------------------------------------
# Post-processing and exported data
# -----------------------------------------------------------------------------
**/postProcessing/
**/VTK/
**/sets/
**/surfaces/
**/logs/

# Meshes generated by blockMesh/snappyHexMesh
**/constant/polyMesh/

# -----------------------------------------------------------------------------
# Common generated outputs
# -----------------------------------------------------------------------------
*.foam
*.OpenFOAM
*.vtk
*.vtp
*.vtu
*.csv
*.dat
*.raw

# Visualization/media outputs
*.png
*.jpg
*.jpeg
*.mp4
*.avi
*.pvsm

# OpenFOAM logs
log.*

# -----------------------------------------------------------------------------
# ParaView
# -----------------------------------------------------------------------------
*.pvd
*.ogv

# -----------------------------------------------------------------------------
# HPC / Slurm logs
# -----------------------------------------------------------------------------
slurm-*.out
*.err

# -----------------------------------------------------------------------------
# Editor backups and OS files
# -----------------------------------------------------------------------------
*~
*.bak
*.swp
.DS_Store

# -----------------------------------------------------------------------------
# Python cache / notebooks
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
.ipynb_checkpoints/

# Python virtual environments
.venv/
venv/
env/