FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      H2O;
}

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0.9;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 0.5;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            zeroGradient;
    }
}
