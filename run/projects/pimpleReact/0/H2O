FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      H2O;
}

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 1;

boundaryField
{
    inlet
    {
        type            fixedValue;
        value           uniform 1;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            zeroGradient;
    }

    // use calculate to enforce species conservation at boundaries as zerogradient overwrites this value otherwise
    cathode
    {
        type            calculated;
        value           uniform 1;
    }

    anode
    {
        type            calculated;
        value           uniform 1;
    }
}
