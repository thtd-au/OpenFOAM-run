FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoamReact;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          0.005;

writeControl    runTime;

writeInterval   0.25;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;

reaction
{
    writeSources     false; // RY_* fields 
}

// Diagnostics check 
speciesConservation
{
    mode                   none;   // none | total | full
    logToInfo              true;
    writeToFile            true;
    allPatchDiagnostics    false;
    printPatchBreakdown    false;
    warningTolerance       1e-20;

    flowPatches            (inlet outlet);
    electrodePatches       (cathode anode);
}

// enable reconstruction of concentration fields from mass-fraction
concentration
{
    runConcentration true;
    writeCFields     false;
}

// enable species saturation tracking
saturation
{
    runSaturation    true;
    writeSFields     false;
    writeSTotField   false;
    writePEqFields   false;
    writePEqTotField false;
}

