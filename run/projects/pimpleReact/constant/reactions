FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant";
    object      reactions;
}

// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

species
(
    H2O
    CO2
    H2
    O2
    Hplus
    OHminus
);

inertSpecie H2O;

FaradayConstant 96485.3329;

diffusivity 
{
    H2O     2.3e-9;
    CO2     1.95e-9;
    H2      3.2e-9;
    O2      3.49e-9;
    OHminus 9.31e-9;
    Hplus   5.27e-9;
    Acetate 1.10e-9;
}   

molarMass 
{
    H2O     0.018015;
    CO2     0.044009;
    H2      0.002016;
    O2      0.031998;
    OHminus 0.017007;
    Hplus   0.0010080;
    Acetate 0.059044;   // CH3COOminus
}   

reactions
{
}

absolutePressureReference 101325;

henryConstant // [mol/m3 Pa]
{
    CO2 3.4e-4;
    H2  7.8e-6;
    O2  1.3e-5;
}

// Diagnostics check 
speciesConservation
{
    mode                   total;   // none | total | full
    logToInfo              true;
    writeToFile            true;
    allPatchDiagnostics    true;
    printPatchBreakdown    false;
    warningTolerance       1e-20;

    flowPatches            (inlet outlet);
    electrodePatches       (cathode anode);
}
