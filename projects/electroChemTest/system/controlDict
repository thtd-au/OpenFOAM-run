FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     electroChem;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          0.0025;

writeControl    runTime;

writeInterval   0.25;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;

// pH
// {
//     runPH          false;
//     writePHField   false;
// }

species
{
    c
    {
        print           true;
        writeSources    false; 
    }

    Y
    {
        print           false;
        write           false; 
    }
}

diagnostics
{
    transport
    {
        print   true;
        log     true;

        species (Hplus OHminus);
    }

    conservation
    {
        print   true;
        log     true;
        mode    residuals; // full | residuals 
        
        flowPatches            (inlet outlet);
        electrodePatches       (cathode anode);
    }

    charge
    {
        output  molarCharge;  // molarCharge | chargeDensity | both
        print   true;
        log     true;
        write   true;     
    }

    saturation
    {
        print
        {
            Si      true;
            STot    true;
            pEqi    false;
            pEqTot  false;
        }

        write
        {
            Si      false;
            STot    false;
            pEqi    false;
            pEqTot  false; 
        }
    }

    inertClosure
    {
        print   true;
    }

    DebyeNumber
    {
        print   true;
        log     true;

        direction 1; // 0=x, 1=y, 2=z
        minIonicSum 1e-6;      // mol/m3

        write
        {
            ionicSum    true;
            lambda_D    true;
            E_D         true;
        }
    }
}

libs
(
    "libCustomBCs.so"
);



