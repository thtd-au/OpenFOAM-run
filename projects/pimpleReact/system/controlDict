FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      controlDict;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

application     pimpleFoamReact;

startFrom       startTime;

startTime       0;

stopAt          endTime;

endTime         5;

deltaT          0.0025;

writeControl    runTime;

writeInterval   0.25;

purgeWrite      0;

writeFormat     ascii;

writePrecision  6;

timeFormat      general;

timePrecision   6;

runTimeModifiable false;

species 
{
    printYFields    true;
    printDiagnostics true;
}

reaction
{
    writeSources     false; // RY_* fields 
}
// enable reconstruction of concentration fields from mass-fraction
concentration
{
    runConcentration true;
    writeCFields     true;
}

pH
{
    runPH          false;
    writePHField   false;
}

// enable species saturation tracking
saturation
{
    runSaturation    true;
    writeSFields     false;
    writeSTotField   false;
    writePEqFields   false;
    writePEqTotField false;
}

// ########### Diagnostics ###################3 
// Transport 
transportDiagnostics
{
    mode    full;   // none | total | full
    species (Hplus OHminus);
}

// Conservation
speciesConservation
{
    mode                   total;   // none | total | full
    logToInfo              true;
    writeToFile            true;
    allPatchDiagnostics    false;
    printPatchBreakdown    false;
    warningTolerance       1e-20;

    flowPatches            (inlet outlet);
    electrodePatches       (cathode anode);
}

// Charge
chargeDiagnostics
{
    mode                   total;        // none | minimal | total | full
    output                 molarCharge;  // molarCharge | chargeDensity | both

    logToInfo              true;
    writeToFile            true;
    writeField             true;

    warningTolerance       1;
}

libs
(
    "libCustomBCs.so"
);



