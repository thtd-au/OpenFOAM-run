FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      Hplus;
}

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
    inlet
    {
    //     type            fixedValue;
    //     value           uniform 0;
        type            pHMassFraction;
        pH              7.0;
    }

    outlet
    {
        type            zeroGradient;
    }

    wall
    {
        type            zeroGradient;
    }

    cathode
    {
        type            zeroGradient;
    }

    anode
    {
        type            faradaicMassFractionFlux;
        stoichCoeff     4;
        nElectrons      4;
        currentDensity  1;
        value           uniform 0;
    }
}
